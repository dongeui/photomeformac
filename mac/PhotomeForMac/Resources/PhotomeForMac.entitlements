<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened runtime 안에서 Python interpreter + PyTorch JIT 가 동작하려면
         아래 셋이 사실상 필수. CLIP 모델 로드 시 stable diffusion 등 third-party
         네이티브 라이브러리가 dlopen되는데, library validation 켜져 있으면 차단된다. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- 업데이트 확인(GitHub API), LAN 공유 시 백엔드 바인딩. offline mode에서도
         GitHub release 폴링은 외부 호출이 필요하므로 client만 허용한다. -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- NSOpenPanel/Drag&Drop으로 사용자가 명시 선택한 폴더 read-only 접근. -->
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>
</dict>
</plist>
